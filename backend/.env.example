# ── Supabase ──────────────────────────────────────────────────────────────────
# Récupérer depuis : supabase.com → Settings → Database → Connection string → URI
# Utiliser le mode "Transaction" (port 6543) pour les apps sans pooler long-lived
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Clé secrète app
SECRET_KEY=changeme

# Environnement
ENVIRONMENT=development
